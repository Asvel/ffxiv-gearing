{
  "compilerOptions": {
    "target": "es2022",
    "module": "preserve",
    "types": ["node", "@rspack/core/module"],
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "useDefineForClassFields": true
  }
}
