{
  "name": "ffxiv-gearing",
  "version": "0.0.1",
  "description": "Final Fantasy XIV Gearing",
  "keywords": [
    "final-fantasy-xiv",
    "ffxiv"
  ],
  "homepage": "https://asvel.github.io/ffxiv-gearing/",
  "license": "MIT",
  "repository": "https://github.com/Asvel/ffxiv-gearing",
  "scripts": {
    "start": "rspack serve",
    "build": "rspack build --mode=production",
    "analyze": "rspack build --mode=production --analyze",
    "publish": "node publish.js",
    "data-fetch": "node data/fetch.js",
    "data-convert": "node data/convert.js",
    "lint": "eslint --ext .js,.ts,.tsx .",
    "test": "playwright test -c test/"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "clsx": "^2.1.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-state-tree": "^7.2.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "sanitize.css": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "confusing-browser-globals": "^1.0.11",
    "css-byebye": "^4.0.1",
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.4",
    "eslint": "^8.57.0",
    "eslint-config-alloy": "^5.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "json5": "^2.2.3",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.9",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.1",
    "sass-embedded": "~1.91.0",
    "sass-loader": "^16.0.7",
    "shelljs": "^0.10.0",
    "simple-functional-loader": "^1.2.1",
    "style-loader": "^4.0.0",
    "svg-sprite-loader": "^6.0.11",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "eslint-config-alloy": {
      "typescript": "$typescript"
    },
    "svg-baker": {
      "postcss": "$postcss"
    }
  }
}
